# =============================================================================
# Bank Scraper Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Database ----------------------------------------------------------------
# Docker Compose default: postgres://scraper:scraper_dev@localhost:5432/bank_scraper?sslmode=disable
DATABASE_URL=postgres://scraper:scraper_dev@localhost:5432/bank_scraper?sslmode=disable

# --- Encryption (Credential Manager) ----------------------------------------
# 64-character hex string (32 bytes). Generate with:
#   openssl rand -hex 32
ENCRYPTION_KEY=

# --- Credential Manager -----------------------------------------------------
CREDMGR_PORT=8081
SESSION_TTL=15m

# --- API Gateway -------------------------------------------------------------
API_PORT=8080

# --- BBVA Scraper (temporary — will move to DB in a future milestone) --------
BBVA_COMPANY_CODE=
BBVA_USER_CODE=
BBVA_PASSWORD=

# --- Scraper Settings --------------------------------------------------------
SCRAPER_TIMEOUT=30s
SCRAPER_HEADLESS=true

# --- Test Mode (not loaded by config — used directly by tests) ---------------
# SCRAPER_TEST_MODE=mock    # mock | replay | live
