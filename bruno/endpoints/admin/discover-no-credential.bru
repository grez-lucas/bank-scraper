meta {
  name: Discover Accounts - No Credential (404)
  type: http
  seq: 2
}

post {
  url: {{api_base_url}}/api/v1/admin/discover/UNKNOWN
  body: none
  auth: none
}

headers {
  X-API-Key: {{api_key}}
}

tests {
  test("returns 404 for unconfigured bank", function() {
    expect(res.status).to.equal(404);
  });
  test("error response format", function() {
    expect(res.body.status).to.equal("error");
    expect(res.body.message).to.include("no credential");
  });
}
